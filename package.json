{
  "name": "claudsidian",
  "version": "0.1.0",
  "description": "Obsidian plugin: chat with Claude Code over your notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node --no-warnings=ExperimentalWarning esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node --no-warnings=ExperimentalWarning esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "claude", "claude-code"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.21.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0"
  }
}
